/ {
	leds {
		led1: led_1 {
			gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>;
			label = "Alert close range";
		};
		led2: led_2 {
			gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
			label = "Alert medium range";
		};
		led3: led_3 {
			gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;
			label = "Alert long range";
		};	
		buzzer1: buzzer_1 {
			gpios = <&gpio0 24 GPIO_ACTIVE_HIGH>;
			label = "Speed alert";
		};
	};

	aliases {
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
		buzzer1 = &buzzer1;
	};
};
